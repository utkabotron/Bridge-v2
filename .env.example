# ============================================================
# Bridge v2 — Environment Variables
# ============================================================
# Copy to .env and fill in values before running

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token_here

# --- OpenAI / LangChain ---
OPENAI_API_KEY=sk-...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=bridge-v2

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- PostgreSQL ---
DATABASE_URL=postgresql://bridge:bridge@postgres:5432/bridge

# --- AWS S3 (media storage) ---
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET=bridge-v2-media

# --- Google BigQuery (analytics) ---
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-sa.json
BIGQUERY_PROJECT=your-gcp-project
BIGQUERY_DATASET=bridge_analytics

# --- Prefect (orchestration) ---
PREFECT_API_URL=https://api.prefect.cloud/api/accounts/.../workspaces/...
PREFECT_API_KEY=pnu_...

# --- Domain & SSL ---
DOMAIN=brdg.tools
WA_SERVICE_PUBLIC_URL=https://brdg.tools

# --- wa-service ---
WA_SERVICE_PORT=3000
WA_SERVICE_URL=http://wa-service:3000
MAX_PARALLEL_INIT=3

# --- processor ---
PROCESSOR_PORT=8000
TARGET_LANGUAGE=Hebrew
TRANSLATION_CACHE_TTL=86400

# --- bot ---
BOT_PORT=8001
ADMIN_TG_IDS=123456789,987654321
